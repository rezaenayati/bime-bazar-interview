NODE_ENV=development
PORT=3000

# Comma-separated list of accepted API keys. Every request must carry one of
# these in the `X-Api-Key` header. Supporting multiple keys at once lets you
# rotate without downtime: deploy with the new + old, switch clients, drop old.
API_KEYS=dev-api-key

DATABASE_HOST=localhost
# docker-compose maps host port 5434 -> container 5432 to avoid clashes with other local Postgres instances.
DATABASE_PORT=5434
DATABASE_USER=bime
DATABASE_PASSWORD=bime
DATABASE_NAME=bime_bazar

# Comma-separated provider fallback chain used when a pay-order allocation
# omits an explicit provider. Order matters: first one tried first.
PAYMENT_PROVIDER_CHAIN=wallet,stripe,paypal

# Failure simulation knobs (0.0 = always succeed, 1.0 = always fail).
STRIPE_FAILURE_RATE=0.2
PAYPAL_FAILURE_RATE=0.2
