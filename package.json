{
  "name": "bime-bazar",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nx build api",
    "start": "node dist/apps/api/apps/api/src/main.js",
    "serve": "nx serve api",
    "test": "nx run-many -t test",
    "test:e2e": "jest --config apps/api/jest.e2e.config.js --runInBand",
    "lint": "nx run-many -t lint",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "db:migrate": "TS_NODE_PROJECT=tsconfig.json ts-node --transpile-only -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d apps/api/src/datasource.ts",
    "db:migrate:revert": "TS_NODE_PROJECT=tsconfig.json ts-node --transpile-only -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d apps/api/src/datasource.ts",
    "db:migrate:gen": "TS_NODE_PROJECT=tsconfig.json ts-node --transpile-only -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d apps/api/src/datasource.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.5",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.5",
    "@nestjs/cqrs": "^10.2.7",
    "@nestjs/platform-express": "^10.4.5",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nestjs-pino": "^4.1.0",
    "pg": "^8.13.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.5",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "nx": "20.3.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
